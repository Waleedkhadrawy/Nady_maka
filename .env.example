NODE_ENV=production
PORT=3001
JWT_SECRET=change_me_to_strong_secret
CORS_ORIGINS=https://your-app.onrender.com

# Supabase/PostgreSQL (preferred)
SUPABASE_CONNECTION_STRING=postgresql://user:password@host:5432/postgres

# Optional fallback
DATABASE_URL=

# Optional Mongo support (disabled by default)
USE_MONGO=false
MONGODB_URI=
