<svg xmlns="http://www.w3.org/2000/svg" width="400" height="300" viewBox="0 0 400 300">
  <defs>
    <linearGradient id="fitnessGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#27ae60;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#1e8449;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Background -->
  <rect width="400" height="300" fill="url(#fitnessGradient)"/>
  
  <!-- Fitness Equipment -->
  <g transform="translate(200, 150)" fill="#fff">
    <!-- Dumbbell -->
    <g transform="translate(-80, -20)">
      <circle cx="0" cy="0" r="15"/>
      <rect x="-5" y="-25" width="10" height="50"/>
      <circle cx="0" cy="-25" r="15"/>
      <circle cx="0" cy="25" r="15"/>
    </g>
    
    <!-- Barbell -->
    <g transform="translate(0, 20)">
      <rect x="-60" y="-3" width="120" height="6"/>
      <circle cx="-60" cy="0" r="20"/>
      <circle cx="60" cy="0" r="20"/>
      <rect x="-65" y="-15" width="10" height="30"/>
      <rect x="55" y="-15" width="10" height="30"/>
    </g>
    
    <!-- Kettlebell -->
    <g transform="translate(80, -30)">
      <circle cx="0" cy="15" r="20"/>
      <rect x="-8" y="-15" width="16" height="20" rx="8"/>
    </g>
    
    <!-- Person Exercising -->
    <g transform="translate(0, -60)">
      <!-- Head -->
      <circle cx="0" cy="0" r="12"/>
      <!-- Body -->
      <rect x="-6" y="12" width="12" height="30" rx="6"/>
      <!-- Arms -->
      <rect x="-25" y="15" width="20" height="6" rx="3"/>
      <rect x="5" y="15" width="20" height="6" rx="3"/>
      <!-- Legs -->
      <rect x="-8" y="42" width="6" height="25" rx="3"/>
      <rect x="2" y="42" width="6" height="25" rx="3"/>
    </g>
  </g>
  
  <!-- Title -->
  <text x="200" y="280" text-anchor="middle" font-family="Arial, sans-serif" font-size="24" font-weight="bold" fill="#fff">اللياقة البدنية</text>
</svg>