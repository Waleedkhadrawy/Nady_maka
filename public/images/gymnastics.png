<svg xmlns="http://www.w3.org/2000/svg" width="400" height="300" viewBox="0 0 400 300">
  <defs>
    <linearGradient id="gymnasticsGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#e74c3c;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#c0392b;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Background -->
  <rect width="400" height="300" fill="url(#gymnasticsGradient)"/>
  
  <!-- Gymnast Figure -->
  <g transform="translate(200, 150)" fill="#fff">
    <!-- Head -->
    <circle cx="0" cy="-80" r="20"/>
    
    <!-- Body -->
    <rect x="-8" y="-60" width="16" height="40" rx="8"/>
    
    <!-- Arms -->
    <rect x="-40" y="-50" width="30" height="8" rx="4" transform="rotate(-30)"/>
    <rect x="10" y="-50" width="30" height="8" rx="4" transform="rotate(30)"/>
    
    <!-- Legs -->
    <rect x="-15" y="-20" width="8" height="35" rx="4" transform="rotate(-20)"/>
    <rect x="7" y="-20" width="8" height="35" rx="4" transform="rotate(20)"/>
    
    <!-- Parallel Bars -->
    <rect x="-80" y="30" width="160" height="4" fill="#8b4513"/>
    <rect x="-80" y="50" width="160" height="4" fill="#8b4513"/>
    
    <!-- Support Posts -->
    <rect x="-85" y="30" width="8" height="40" fill="#654321"/>
    <rect x="77" y="30" width="8" height="40" fill="#654321"/>
  </g>
  
  <!-- Title -->
  <text x="200" y="280" text-anchor="middle" font-family="Arial, sans-serif" font-size="24" font-weight="bold" fill="#fff">الجمباز</text>
</svg>