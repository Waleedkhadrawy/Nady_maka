<svg width="400" height="300" viewBox="0 0 400 300" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="videoGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#2C3E50;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#34495E;stop-opacity:1" />
    </linearGradient>
    <linearGradient id="playGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#E74C3C;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#C0392B;stop-opacity:1" />
    </linearGradient>
    <radialGradient id="glowEffect" cx="50%" cy="50%" r="50%">
      <stop offset="0%" style="stop-color:#FFFFFF;stop-opacity:0.3" />
      <stop offset="100%" style="stop-color:#FFFFFF;stop-opacity:0" />
    </radialGradient>
  </defs>
  
  <!-- Video Background -->
  <rect width="400" height="300" fill="url(#videoGradient)" rx="10"/>
  
  <!-- Video Content Background -->
  <rect x="20" y="40" width="360" height="220" fill="#1A252F" rx="5"/>
  
  <!-- Gym/Sports Scene -->
  <!-- Floor -->
  <rect x="20" y="200" width="360" height="60" fill="#8D6E63"/>
  
  <!-- Equipment Silhouettes -->
  <!-- Treadmill -->
  <rect x="50" y="180" width="80" height="40" fill="#455A64" rx="5"/>
  <rect x="60" y="170" width="60" height="10" fill="#37474F" rx="2"/>
  <circle cx="70" cy="220" r="8" fill="#263238"/>
  <circle cx="110" cy="220" r="8" fill="#263238"/>
  
  <!-- Weight Rack -->
  <rect x="160" y="160" width="60" height="60" fill="#455A64"/>
  <rect x="170" y="150" width="40" height="10" fill="#37474F"/>
  <circle cx="175" cy="155" r="3" fill="#E74C3C"/>
  <circle cx="185" cy="155" r="3" fill="#E74C3C"/>
  <circle cx="195" cy="155" r="3" fill="#E74C3C"/>
  <circle cx="205" cy="155" r="3" fill="#E74C3C"/>
  
  <!-- Exercise Bike -->
  <rect x="250" y="170" width="50" height="50" fill="#455A64" rx="3"/>
  <circle cx="260" cy="210" r="12" fill="#263238"/>
  <circle cx="290" cy="210" r="8" fill="#263238"/>
  <rect x="270" y="160" width="20" height="30" fill="#37474F" rx="2"/>
  
  <!-- People Silhouettes -->
  <!-- Person 1 -->
  <circle cx="320" cy="140" r="12" fill="#546E7A"/>
  <rect x="315" y="152" width="10" height="30" fill="#546E7A" rx="2"/>
  <rect x="310" y="165" width="8" height="20" fill="#546E7A" rx="1"/>
  <rect x="322" y="165" width="8" height="20" fill="#546E7A" rx="1"/>
  <rect x="308" y="182" width="6" height="15" fill="#546E7A" rx="1"/>
  <rect x="326" y="182" width="6" height="15" fill="#546E7A" rx="1"/>
  
  <!-- Person 2 (smaller, in background) -->
  <circle cx="100" cy="120" r="8" fill="#607D8B" opacity="0.7"/>
  <rect x="96" y="128" width="8" height="25" fill="#607D8B" opacity="0.7" rx="1"/>
  <rect x="92" y="138" width="6" height="15" fill="#607D8B" opacity="0.7" rx="1"/>
  <rect x="102" y="138" width="6" height="15" fill="#607D8B" opacity="0.7" rx="1"/>
  
  <!-- Lighting Effects -->
  <rect x="20" y="40" width="360" height="220" fill="url(#glowEffect)" rx="5"/>
  
  <!-- Play Button -->
  <circle cx="200" cy="150" r="40" fill="url(#playGradient)" stroke="#FFFFFF" stroke-width="3" opacity="0.9"/>
  <polygon points="185,135 185,165 215,150" fill="#FFFFFF"/>
  
  <!-- Play Button Glow -->
  <circle cx="200" cy="150" r="45" fill="none" stroke="#E74C3C" stroke-width="2" opacity="0.5">
    <animate attributeName="r" values="45;50;45" dur="2s" repeatCount="indefinite"/>
    <animate attributeName="opacity" values="0.5;0.2;0.5" dur="2s" repeatCount="indefinite"/>
  </circle>
  
  <!-- Video Title Bar -->
  <rect x="20" y="40" width="360" height="30" fill="#E74C3C" rx="5 5 0 0"/>
  <text x="200" y="60" text-anchor="middle" fill="white" font-family="Arial, sans-serif" font-size="14" font-weight="bold">كيفية التسجيل في مكة يارد</text>
  
  <!-- Video Controls Bar -->
  <rect x="20" y="240" width="360" height="20" fill="#1A252F" rx="0 0 5 5" opacity="0.8"/>
  <rect x="30" y="245" width="100" height="10" fill="#E74C3C" rx="5"/>
  <rect x="130" y="245" width="240" height="10" fill="#455A64" rx="5"/>
  <circle cx="130" cy="250" r="6" fill="#FFFFFF"/>
  
  <!-- Duration Text -->
  <text x="350" y="255" text-anchor="end" fill="white" font-family="Arial, sans-serif" font-size="10">2:45</text>
</svg>