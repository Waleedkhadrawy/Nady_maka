<svg xmlns="http://www.w3.org/2000/svg" width="400" height="300" viewBox="0 0 400 300">
  <defs>
    <linearGradient id="karateGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#f39c12;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#d68910;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Background -->
  <rect width="400" height="300" fill="url(#karateGradient)"/>
  
  <!-- Karate Fighter -->
  <g transform="translate(200, 150)" fill="#fff">
    <!-- Head -->
    <circle cx="0" cy="-70" r="18"/>
    
    <!-- Body -->
    <rect x="-10" y="-52" width="20" height="45" rx="10"/>
    
    <!-- Karate Gi (Uniform) -->
    <rect x="-12" y="-52" width="24" height="50" rx="2" fill="none" stroke="#fff" stroke-width="2"/>
    
    <!-- Belt -->
    <rect x="-15" y="-15" width="30" height="6" fill="#000"/>
    
    <!-- Arms in Fighting Position -->
    <rect x="-35" y="-40" width="25" height="8" rx="4" transform="rotate(-45)"/>
    <rect x="10" y="-45" width="25" height="8" rx="4" transform="rotate(30)"/>
    
    <!-- Legs in Stance -->
    <rect x="-12" y="-7" width="8" height="40" rx="4" transform="rotate(-15)"/>
    <rect x="4" y="-7" width="8" height="40" rx="4" transform="rotate(25)"/>
    
    <!-- Action Lines (Movement) -->
    <g stroke="#fff" stroke-width="2" fill="none" opacity="0.7">
      <path d="M 30 -30 Q 40 -25 45 -15"/>
      <path d="M 35 -20 Q 45 -15 50 -5"/>
      <path d="M 40 -10 Q 50 -5 55 5"/>
    </g>
  </g>
  
  <!-- Dojo Floor Pattern -->
  <g opacity="0.2">
    <rect x="0" y="250" width="400" height="50" fill="#8b4513"/>
    <line x1="0" y1="275" x2="400" y2="275" stroke="#654321" stroke-width="2"/>
  </g>
  
  <!-- Title -->
  <text x="200" y="280" text-anchor="middle" font-family="Arial, sans-serif" font-size="24" font-weight="bold" fill="#fff">الكاراتيه</text>
</svg>