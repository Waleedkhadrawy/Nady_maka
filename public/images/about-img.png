<svg width="600" height="400" viewBox="0 0 600 400" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="poolGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#4FC3F7;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#29B6F6;stop-opacity:1" />
    </linearGradient>
    <linearGradient id="buildingGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#E0E0E0;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#BDBDBD;stop-opacity:1" />
    </linearGradient>
    <linearGradient id="skyGradient" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:#87CEEB;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#E0F6FF;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Sky Background -->
  <rect width="600" height="400" fill="url(#skyGradient)"/>
  
  <!-- Building Structure -->
  <rect x="50" y="100" width="500" height="250" fill="url(#buildingGradient)" stroke="#9E9E9E" stroke-width="2"/>
  
  <!-- Roof -->
  <polygon points="30,100 300,50 570,100" fill="#795548" stroke="#5D4037" stroke-width="2"/>
  
  <!-- Pool Area -->
  <ellipse cx="300" cy="280" rx="200" ry="80" fill="url(#poolGradient)" stroke="#0277BD" stroke-width="3"/>
  
  <!-- Pool Lanes -->
  <line x1="150" y1="260" x2="150" y2="300" stroke="#FFFFFF" stroke-width="2" opacity="0.7"/>
  <line x1="200" y1="250" x2="200" y2="310" stroke="#FFFFFF" stroke-width="2" opacity="0.7"/>
  <line x1="250" y1="245" x2="250" y2="315" stroke="#FFFFFF" stroke-width="2" opacity="0.7"/>
  <line x1="350" y1="245" x2="350" y2="315" stroke="#FFFFFF" stroke-width="2" opacity="0.7"/>
  <line x1="400" y1="250" x2="400" y2="310" stroke="#FFFFFF" stroke-width="2" opacity="0.7"/>
  <line x1="450" y1="260" x2="450" y2="300" stroke="#FFFFFF" stroke-width="2" opacity="0.7"/>
  
  <!-- Windows -->
  <rect x="80" y="130" width="60" height="80" fill="#81D4FA" stroke="#0277BD" stroke-width="2"/>
  <rect x="180" y="130" width="60" height="80" fill="#81D4FA" stroke="#0277BD" stroke-width="2"/>
  <rect x="360" y="130" width="60" height="80" fill="#81D4FA" stroke="#0277BD" stroke-width="2"/>
  <rect x="460" y="130" width="60" height="80" fill="#81D4FA" stroke="#0277BD" stroke-width="2"/>
  
  <!-- Window Frames -->
  <line x1="110" y1="130" x2="110" y2="210" stroke="#0277BD" stroke-width="1"/>
  <line x1="80" y1="170" x2="140" y2="170" stroke="#0277BD" stroke-width="1"/>
  <line x1="210" y1="130" x2="210" y2="210" stroke="#0277BD" stroke-width="1"/>
  <line x1="180" y1="170" x2="240" y2="170" stroke="#0277BD" stroke-width="1"/>
  <line x1="390" y1="130" x2="390" y2="210" stroke="#0277BD" stroke-width="1"/>
  <line x1="360" y1="170" x2="420" y2="170" stroke="#0277BD" stroke-width="1"/>
  <line x1="490" y1="130" x2="490" y2="210" stroke="#0277BD" stroke-width="1"/>
  <line x1="460" y1="170" x2="520" y2="170" stroke="#0277BD" stroke-width="1"/>
  
  <!-- Main Entrance -->
  <rect x="270" y="220" width="60" height="130" fill="#8D6E63" stroke="#5D4037" stroke-width="2"/>
  <circle cx="315" cy="285" r="3" fill="#FFD54F"/>
  
  <!-- Logo/Sign -->
  <rect x="250" y="140" width="100" height="40" fill="#E74C3C" stroke="#C0392B" stroke-width="2" rx="5"/>
  <text x="300" y="165" text-anchor="middle" fill="white" font-family="Arial, sans-serif" font-size="14" font-weight="bold">MAKKAH</text>
  <text x="300" y="180" text-anchor="middle" fill="white" font-family="Arial, sans-serif" font-size="12">YARD</text>
  
  <!-- Decorative Elements -->
  <circle cx="120" cy="320" r="15" fill="#4CAF50" opacity="0.7"/>
  <circle cx="480" cy="320" r="15" fill="#4CAF50" opacity="0.7"/>
  <circle cx="150" cy="340" r="10" fill="#8BC34A" opacity="0.6"/>
  <circle cx="450" cy="340" r="10" fill="#8BC34A" opacity="0.6"/>
  
  <!-- Water Reflection Effect -->
  <ellipse cx="300" cy="280" rx="180" ry="60" fill="none" stroke="#FFFFFF" stroke-width="1" opacity="0.3"/>
  <ellipse cx="300" cy="285" rx="160" ry="50" fill="none" stroke="#FFFFFF" stroke-width="1" opacity="0.2"/>
</svg>